{
  "name": "irctc-tatkal-booking",
  "version": "1.0.0",
  "description": "IRCTC Tatkal Ticket Booking Desktop Software",
  "main": "public/electron.js",
  "homepage": "./",
  "author": "Shree Services Solutions",
  "license": "MIT",
  "scripts": {
    "react-start": "react-scripts start",
    "react-build": "react-scripts build",
    "react-test": "react-scripts test",
    "react-eject": "react-scripts eject",
    "electron-start": "electron .",
    "electron-dev": "concurrently \"npm run react-start\" \"wait-on http://localhost:3000 && npm run electron-start\"",
    "electron-build": "npm run react-build && electron-builder",
    "dev": "npm run electron-dev",
    "build": "npm run electron-build"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "electron-squirrel-startup": "^1.1.0",
    "electron-store": "^8.1.0",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "node-schedule": "^2.1.1",
    "sqlite3": "^5.1.6",
    "uuid": "^9.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.8.0",
    "react-toastify": "^9.1.2",
    "lucide-react": "^0.263.1"
  },
  "devDependencies": {
    "react-scripts": "5.0.1",
    "@testing-library/react": "^13.4.0",
    "@testing-library/jest-dom": "^5.16.5",
    "concurrently": "^7.6.0",
    "electron": "^22.0.0",
    "electron-builder": "^24.1.1",
    "electron-is-dev": "^2.0.0",
    "wait-on": "^7.0.1"
  },
  "build": {
    "appId": "com.irctc.tatkal",
    "productName": "IRCTC Tatkal Booking",
    "files": [
      "public/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "assets"
    }
  }
}
